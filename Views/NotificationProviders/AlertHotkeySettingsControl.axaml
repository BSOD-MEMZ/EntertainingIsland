<ci:NotificationProviderControlBase
    x:Class="EntertainingIsland.Views.NotificationProviders.AlertHotkeySettingsControl"
    x:TypeArguments="models:AlertHotkeySettings"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:local="clr-namespace:EntertainingIsland.Views.NotificationProviders"
    xmlns:models="clr-namespace:EntertainingIsland.Models"
    mc:Ignorable="d"
    d:DesignHeight="500" d:DesignWidth="800">

    <ScrollViewer>
        <StackPanel DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:AlertHotkeySettingsControl}}"
                Classes="settings-container animated-intro">

        <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xEDE9;}"
                             Header="启用警报功能"
                             Description="开启后，按下警报快捷键即可弹出 ClassIsland 原生通知警报。">
            <fa:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding Settings.EnableTeacherAlert}" />
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>

        <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xEDE9;}"
                             Header="警报消息内容"
                             Description="触发警报时显示的消息文本。">
            <fa:SettingsExpander.Footer>
                <TextBox Text="{Binding Settings.AlertMessage}"
                         Width="260"
                         Watermark="窗外有老师！" />
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>

        <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xF263;}"
                             Header="警报快捷键"
                             Description="{Binding Settings.AlertHotkey.DisplayString, StringFormat='当前：{0}'}"
                             IsExpanded="False">
            <StackPanel Spacing="8" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <CheckBox IsChecked="{Binding Settings.AlertHotkey.Ctrl}" Content="Ctrl" />
                    <CheckBox IsChecked="{Binding Settings.AlertHotkey.Shift}" Content="Shift" />
                    <CheckBox IsChecked="{Binding Settings.AlertHotkey.Alt}" Content="Alt" />
                    <CheckBox IsChecked="{Binding Settings.AlertHotkey.Win}" Content="Win" />
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="主按键" FontSize="12" Opacity="0.7" />
                    <ComboBox SelectedItem="{Binding Settings.AlertHotkey.Key}"
                              Width="120"
                              ItemsSource="{Binding KeyOptions}" />
                </StackPanel>
            </StackPanel>
        </fa:SettingsExpander>

        <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xF361;}"
                             Header="显示时长"
                             Description="通知显示的持续秒数（3-120）。">
            <fa:SettingsExpander.Footer>
                <NumericUpDown Value="{Binding Settings.AlertDurationSeconds}"
                               Minimum="3" Maximum="120"
                               Increment="5" Width="120" />
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>

        <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xF265;}"
                             Header="启用强调效果"
                             Description="使用当前 ClassIsland 主题色作为涟漪动画颜色。">
            <fa:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding Settings.EnableEmphasisEffect}" />
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>

        <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xEB70;}"
                             Header="启用语音播报"
                             Description="触发警报时播报警告语音。">
            <fa:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding Settings.EnableSpeech}" />
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>

        <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xF00D;}"
                             Header="启用提示音效"
                             Description="触发警报时播放提示音。">
            <fa:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding Settings.EnableSound}" />
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>

        <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xEAB0;}"
                             Header="通知时置顶主窗口"
                             Description="触发警报时将 ClassIsland 主窗口置顶。">
            <fa:SettingsExpander.Footer>
                <ToggleSwitch IsChecked="{Binding Settings.EnableTopmost}" />
            </fa:SettingsExpander.Footer>
        </fa:SettingsExpander>

    </StackPanel>
    </ScrollViewer>
</ci:NotificationProviderControlBase>
