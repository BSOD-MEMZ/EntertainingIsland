<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="EntertainingIsland.Views.WelcomePages.QuickSetupPage">
    <Grid RowDefinitions="Auto, *, Auto" Margin="32,16">
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="⚙️ 快速设置" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="选择你想要启用的功能，之后可在插件设置中随时更改。" FontSize="14" Opacity="0.6" TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="8">
            <fa:SettingsExpander Header="防巡堂警报"
                                 Description="按下热键立即弹出全屏警告。"
                                 IconSource="{x:Null}">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding EnableAlertHotkey}" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander Header="小说阅读器"
                                 Description="在课表组件中阅读 txt 小说。"
                                 IconSource="{x:Null}">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding EnableNovelReader}" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander Header="每日运势"
                                 Description="每日随机宜忌运势，高中生专属趣味指南。"
                                 IconSource="{x:Null}">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding EnableFortune}" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander Header="口头禅记录"
                                 Description="记录老师经典语录并计数。"
                                 IconSource="{x:Null}">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding EnableCatchphrase}" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander Header="体育赛事"
                                 Description="显示 NBA / 英超 / 西甲实时比分。"
                                 IconSource="{x:Null}">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding EnableSports}" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander Header="全局安全键"
                                 Description="一键消警并隐藏所有娱乐组件，再按恢复。"
                                 IconSource="{x:Null}"
                                 IsExpanded="False">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox IsChecked="{Binding DismissKeyCtrl}" Content="Ctrl" />
                        <CheckBox IsChecked="{Binding DismissKeyShift}" Content="Shift" />
                        <CheckBox IsChecked="{Binding DismissKeyAlt}" Content="Alt" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="主按键" FontSize="12" Opacity="0.7" />
                        <ComboBox SelectedItem="{Binding DismissKeyKey}" Width="100">
                            <ComboBoxItem Content="K" />
                            <ComboBoxItem Content="F1" />
                            <ComboBoxItem Content="F2" />
                            <ComboBoxItem Content="F12" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </fa:SettingsExpander>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Content="上一步" Click="ButtonBack_OnClick" />
            <Button Content="下一步" Classes="accent" Click="ButtonNext_OnClick" />
        </StackPanel>
    </Grid>
</UserControl>
