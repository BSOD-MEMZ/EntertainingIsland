<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="EntertainingIsland.Views.WelcomePages.SoundChoicePage">
    <Grid RowDefinitions="*, Auto, Auto, *" Margin="32,16">
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Spacing="16">
            <ci:FluentIcon Glyph="&#xF00C;" FontSize="48" HorizontalAlignment="Center" Foreground="{DynamicResource SystemAccentColorBrush}" />
            <TextBlock Text="是否开启欢迎音效？"
                       FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="开启后，欢迎向导将播放背景音乐配合动画。"
                       FontSize="14" Opacity="0.6" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="360" TextAlignment="Center" />
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,32,0,0">
            <Button Content="静音进入" Width="140" Height="40" Click="ButtonMute_OnClick" />
            <Button Content="开启声音" Width="140" Height="40" Classes="accent" Click="ButtonSound_OnClick" />
        </StackPanel>
    </Grid>
</UserControl>
