<ci:SettingsPageBase 
    x:Class="EntertainingIsland.Views.SettingsPages.CameraMonitorSettingsPage"
    x:Name="RootPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:local="clr-namespace:EntertainingIsland.Views.SettingsPages"
    mc:Ignorable="d" 
    d:DesignHeight="400" d:DesignWidth="800"
    d:DataContext="{d:DesignInstance local:CameraMonitorSettingsPage}">

    <ScrollViewer>
        <StackPanel Classes="settings-container animated-intro">

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xEDE9;}"
                                 Header="启用摄像头监控"
                                 Description="摄像头被调用时，信息岛显示绿色圆点提醒。">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Camera.EnableCameraMonitor}" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE4BA;}"
                                 Header="轮询间隔"
                                 Description="检测摄像头状态的频率（毫秒）。最小 500ms，默认 2000ms。">
                <fa:SettingsExpander.Footer>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Slider Value="{Binding Camera.PollingIntervalMs}"
                                Minimum="500" Maximum="10000"
                                TickFrequency="500"
                                Width="120" />
                        <TextBlock Text="{Binding Camera.PollingIntervalMs, StringFormat='{}{0} ms'}"
                                   Width="70" VerticalAlignment="Center" />
                    </StackPanel>
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

        </StackPanel>
    </ScrollViewer>

</ci:SettingsPageBase>
