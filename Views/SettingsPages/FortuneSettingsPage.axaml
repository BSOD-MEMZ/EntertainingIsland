<ci:SettingsPageBase 
    x:Class="EntertainingIsland.Views.SettingsPages.FortuneSettingsPage"
    x:Name="RootPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:local="clr-namespace:EntertainingIsland.Views.SettingsPages"
    xmlns:models="clr-namespace:EntertainingIsland.Models"
    mc:Ignorable="d" 
    d:DesignHeight="900" d:DesignWidth="800"
    d:DataContext="{d:DesignInstance local:FortuneSettingsPage}">

    <ScrollViewer>
        <StackPanel Classes="settings-container animated-intro">

            <ci:IconText Glyph="&#xE8D6;" Text="每日运势" Margin="0 0 0 4" />

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xEDE9;}"
                                 Header="启用每日运势"
                                 Description="在信息岛显示每日宜忌运势。">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Fortune.IsEnabled}" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE117;}"
                                 Header="立即刷新"
                                 Description="重新随机抽取今日运势。">
                <fa:SettingsExpander.Footer>
                    <Button Content="🔄 立即刷新" Click="Refresh_Click" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE8D6;}"
                                 Header="每日显示数量"
                                 Description="宜和忌各显示几条。">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="宜:" VerticalAlignment="Center" Width="30" />
                        <NumericUpDown Value="{Binding Fortune.GoodCount}"
                                       Minimum="1" Maximum="5" Width="100" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="忌:" VerticalAlignment="Center" Width="30" />
                        <NumericUpDown Value="{Binding Fortune.BadCount}"
                                       Minimum="1" Maximum="5" Width="100" />
                    </StackPanel>
                </StackPanel>
            </fa:SettingsExpander>

            <Separator Margin="0 12 0 4" />

            <!-- 宜条目池 -->
            <ci:IconText Glyph="&#xF05B;" Text="宜... 条目池" Margin="0 0 0 4" />

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xF05B;}"
                                 Header="宜... 条目池"
                                 Description="每天随机从池中抽取「宜」条目。"
                                 IsExpanded="True">
                <StackPanel Spacing="6" Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding Fortune.GoodFortunes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:FortuneEntry">
                                <Border Padding="8,4" Margin="0,2" CornerRadius="4"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                    <Grid ColumnDefinitions="*,*,Auto" VerticalAlignment="Center">
                                        <TextBox Grid.Column="0" Text="{Binding MainText}"
                                                 Watermark="主标题（如：高考）" Margin="0,0,4,0" />
                                        <TextBox Grid.Column="1" Text="{Binding SubText}"
                                                 Watermark="副标题（如：金榜题名）" Margin="0,0,4,0" />
                                        <Button Grid.Column="2" Content="✕" Width="26" Height="26"
                                                Tag="{Binding}"
                                                Click="DeleteGood_Click"
                                                Theme="{StaticResource TransparentButton}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ 添加条目" Click="AddGood_Click"
                            Theme="{StaticResource TransparentButton}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </fa:SettingsExpander>

            <Separator Margin="0 12 0 4" />

            <!-- 忌条目池 -->
            <ci:IconText Glyph="&#xF05B;" Text="忌... 条目池" Margin="0 0 0 4" />

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xF05B;}"
                                 Header="忌... 条目池"
                                 Description="每天随机从池中抽取「忌」条目。"
                                 IsExpanded="True">
                <StackPanel Spacing="6" Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding Fortune.BadFortunes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:FortuneEntry">
                                <Border Padding="8,4" Margin="0,2" CornerRadius="4"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                    <Grid ColumnDefinitions="*,*,Auto" VerticalAlignment="Center">
                                        <TextBox Grid.Column="0" Text="{Binding MainText}"
                                                 Watermark="主标题（如：去食堂）" Margin="0,0,4,0" />
                                        <TextBox Grid.Column="1" Text="{Binding SubText}"
                                                 Watermark="副标题（如：爱吃的菜刚被打完）" Margin="0,0,4,0" />
                                        <Button Grid.Column="2" Content="✕" Width="26" Height="26"
                                                Tag="{Binding}"
                                                Click="DeleteBad_Click"
                                                Theme="{StaticResource TransparentButton}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ 添加条目" Click="AddBad_Click"
                            Theme="{StaticResource TransparentButton}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </fa:SettingsExpander>

        </StackPanel>
    </ScrollViewer>

</ci:SettingsPageBase>
