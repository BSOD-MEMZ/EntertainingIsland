<ci:ComponentBase x:TypeArguments="models:CatchphraseComponentSettings"
    x:Class="EntertainingIsland.Views.Components.CatchphraseComponentSettingsControl"
    x:Name="SettingsRoot"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:models="clr-namespace:EntertainingIsland.Models"
    xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:local="clr-namespace:EntertainingIsland.Views.Components"
    mc:Ignorable="d"
    d:DesignHeight="500" d:DesignWidth="450">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:CatchphraseComponentSettingsControl}}">
        <StackPanel Classes="settings-container animated-intro">

            <fa:InfoBar Message="修改快捷键后需重启 ClassIsland 生效。"
                        IsOpen="True" IsClosable="False" Severity="Warning" />

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE3E4;}"
                                 Header="口头禅预设"
                                 Description="为常用口头禅配置独立快捷键，按下即可 +1。"
                                 IsExpanded="True">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding GlobalPresets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,3" CornerRadius="4"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                    <Grid ColumnDefinitions="120, Auto, 70, 30" RowDefinitions="Auto" VerticalAlignment="Center">
                                        <TextBox Grid.Column="0" Text="{Binding Phrase}"
                                                 Watermark="口头禅文字" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                    Margin="8,0,0,0" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding Hotkey.Ctrl}" Content="Ctrl" FontSize="11" />
                                            <CheckBox IsChecked="{Binding Hotkey.Shift}" Content="Shift" FontSize="11" />
                                            <CheckBox IsChecked="{Binding Hotkey.Alt}" Content="Alt" FontSize="11" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="2" SelectedItem="{Binding Hotkey.Key}" Width="60"
                                                  Margin="8,0,0,0"
                                                  ItemsSource="{Binding #SettingsRoot.KeyOptions}"
                                                  VerticalAlignment="Center" />
                                        <Button Grid.Column="3" Content="✕" Width="26" Height="26"
                                                Margin="4,0,0,0"
                                                Tag="{Binding}"
                                                Click="DeletePreset_Click"
                                                Theme="{StaticResource TransparentButton}"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                Foreground="IndianRed" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="＋ 添加预设" x:Name="AddBtn" HorizontalAlignment="Left" />
                </StackPanel>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE91B;}"
                                 Header="口头禅强调提醒"
                                 Description="老师每说一次口头禅，弹出 1 秒强调提醒。">
                <fa:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding PluginSettings.CatchphraseEmphasisEnabled}" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xE74D;}"
                                 Header="清空统计"
                                 Description="清除所有口头禅计数记录。">
                <fa:SettingsExpander.Footer>
                    <Button Content="清空" x:Name="ClearBtn" />
                </fa:SettingsExpander.Footer>
            </fa:SettingsExpander>

        </StackPanel>
    </ScrollViewer>

</ci:ComponentBase>
