<UserControl x:Class="EntertainingIsland.Views.Components.ClassEndingNotificationControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:EntertainingIsland.Views.Components"
             xmlns:converters1="clr-namespace:ClassIsland.Core.Converters;assembly=ClassIsland.Core"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             d:DataContext="{d:DesignInstance local:ClassEndingNotificationControl}"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <converters1:TimeSpanToTotalSecondsConverter x:Key="TimeSpanToTotalSecondsConverter" />

        <!-- 下课倒计时 -->
        <Grid x:Key="ClassEndingOverlay" ColumnDefinitions="*,*">

            <!-- 倒计时 -->
            <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="12 0">
                <Run Text="距下课还剩" Classes="l-instructive"/>
                <Run Text="{Binding LessonsService.OnBreakingTimeLeftTime, Converter={StaticResource TimeSpanToTotalSecondsConverter}, Mode=OneWay}"
                     FontWeight="Bold"/>
                <Run Text="秒" Classes="l-instructive"/>
            </TextBlock>

            <!-- 科目信息 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal"
                        Margin="12 0">
                <TextBlock VerticalAlignment="Center" Text="下节课是：" Classes="l-instructive"/>
                <TextBlock Text="{Binding NextSubjectName}" FontWeight="Bold" FontSize="{DynamicResource MainWindowLargeFontSize}" VerticalAlignment="Center"/>
                <TextBlock Margin="6 0 0 0" FontSize="{DynamicResource MainWindowSecondaryFontSize}" VerticalAlignment="Bottom"
                           Text="{Binding NextSubjectTeacherName}"
                           IsVisible="{Binding ShowTeacherName}"
                           Classes="l-secondary"/>
                <TextBlock FontSize="{DynamicResource MainWindowSecondaryFontSize}" VerticalAlignment="Bottom" Margin="2 0 0 0"
                           Classes="l-secondary">
                    <Run Text="{Binding NextClassStartTime, StringFormat={}{0:hh\\:mm}}">
                    </Run><Run Text="-">
                    </Run><Run Text="{Binding NextClassEndTime, StringFormat={}{0:hh\\:mm}}"/>
                </TextBlock>
            </StackPanel>
        </Grid>
    </UserControl.Resources>
    <Grid Margin="16 0" DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:ClassEndingNotificationControl}}">
        <ListBox
            x:Name="MainListBox"
            Classes="sliding">
            <ListBoxItem FontSize="{DynamicResource MainWindowBodyFontSize}"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                <ContentPresenter Content="{Binding Element, RelativeSource={RelativeSource FindAncestor, AncestorType=local:ClassEndingNotificationControl}}"/>
            </ListBoxItem>
            <ListBoxItem FontSize="{DynamicResource MainWindowBodyFontSize}"
                         Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                <TextBlock Text="{Binding Message, RelativeSource={RelativeSource FindAncestor, AncestorType=local:ClassEndingNotificationControl}}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </ListBoxItem>
        </ListBox>
    </Grid>
</UserControl>
