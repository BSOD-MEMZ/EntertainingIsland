<ci:ComponentBase x:TypeArguments="models:AvatarClassScheduleSettings"
    x:Class="EntertainingIsland.Views.Components.AvatarClassScheduleComponent"
    x:Name="Root"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:models="clr-namespace:EntertainingIsland.Models"
    xmlns:local="clr-namespace:EntertainingIsland.Views.Components"
    mc:Ignorable="d"
    d:DesignHeight="40" d:DesignWidth="800">

    <ItemsControl x:Name="ClassListControl"
                  VerticalAlignment="Center"
                  Margin="4,0">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="4" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
    </ItemsControl>

</ci:ComponentBase>
