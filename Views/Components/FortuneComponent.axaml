<ci:ComponentBase
    x:Class="EntertainingIsland.Views.Components.FortuneComponent"
    x:TypeArguments="models:FortuneComponentSettings"
    xmlns="https://github.com/avaloniaui"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="clr-namespace:EntertainingIsland.Models"
    mc:Ignorable="d"
    d:DesignHeight="44" d:DesignWidth="280">

    <StackPanel Spacing="2" VerticalAlignment="Center" Margin="4,2">
        <TextBlock x:Name="GoodLine" FontSize="12" TextWrapping="Wrap" />
        <TextBlock x:Name="BadLine" FontSize="12" TextWrapping="Wrap" />
    </StackPanel>

</ci:ComponentBase>
