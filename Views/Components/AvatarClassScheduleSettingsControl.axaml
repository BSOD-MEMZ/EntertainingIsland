<ci:ComponentBase x:TypeArguments="models:AvatarClassScheduleSettings"
    x:Class="EntertainingIsland.Views.Components.AvatarClassScheduleSettingsControl"
    x:Name="SettingsRoot"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:models="clr-namespace:EntertainingIsland.Models"
    xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:local="clr-namespace:EntertainingIsland.Views.Components"
    mc:Ignorable="d"
    d:DesignHeight="700" d:DesignWidth="500">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:AvatarClassScheduleSettingsControl}}">
        <StackPanel Classes="settings-container animated-intro">

            <ci:IconText Glyph="&#xECE5;" Text="科目头像映射" Margin="0 0 0 4" />

            <!-- ===== 科目头像映射 ===== -->
            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xECE5;}"
                                 Header="科目头像映射"
                                 Description="为每个科目设置对应的教师头像图片。留空则显示默认圆形头像（科目简称）。"
                                 IsExpanded="True">
                <StackPanel Spacing="4" Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding SubjectAvatarRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" Margin="0,2" CornerRadius="4"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                          VerticalAlignment="Center">
                                        <!-- 当前头像预览 -->
                                        <Border Grid.Column="0"
                                                Width="32" Height="32"
                                                CornerRadius="16"
                                                ClipToBounds="True"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center">
                                            <Panel>
                                                <Image Source="{Binding AvatarPreview}"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding HasAvatar}" />
                                                <Border Background="{DynamicResource SystemAccentColor}"
                                                        IsVisible="{Binding !HasAvatar}">
                                                    <TextBlock Text="{Binding SubjectInitial}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="White" />
                                                </Border>
                                            </Panel>
                                        </Border>

                                        <!-- 科目名 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding SubjectName}"
                                                       FontSize="13" FontWeight="Bold" />
                                            <TextBlock Text="{Binding AvatarPath, StringFormat='路径：{0}'}"
                                                       FontSize="10" Opacity="0.6"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="180" />
                                        </StackPanel>

                                        <!-- 浏览按钮 -->
                                        <Button Grid.Column="2"
                                                Content="...浏览..."
                                                Tag="{Binding}"
                                                Click="OnBrowseAvatar_Click"
                                                Margin="4,0"
                                                Theme="{StaticResource TransparentButton}"
                                                FontSize="11" />

                                        <!-- 清除按钮 -->
                                        <Button Grid.Column="3"
                                                Content="清除"
                                                Tag="{Binding}"
                                                Click="OnClearAvatar_Click"
                                                Theme="{StaticResource TransparentButton}"
                                                FontSize="11"
                                                Foreground="IndianRed" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </fa:SettingsExpander>

            <!-- ===== 头像外观 ===== -->
            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xEC4A;}"
                                 Header="头像外观"
                                 Description="设置头像的大小和圆角。"
                                 IsExpanded="True">

                <fa:SettingsExpanderItem Content="已上课头像大小"
                                         Description="已结束课程头像的像素大小（20-64）。">
                    <fa:SettingsExpanderItem.Footer>
                        <NumericUpDown Value="{Binding Settings.PastAvatarSize}"
                                       Minimum="20" Maximum="64"
                                       Increment="4" Width="120" />
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="当前课头像大小"
                                         Description="正在上课的头像像素大小（20-64），建议比未上课稍大。">
                    <fa:SettingsExpanderItem.Footer>
                        <NumericUpDown Value="{Binding Settings.CurrentAvatarSize}"
                                       Minimum="20" Maximum="64"
                                       Increment="4" Width="120" />
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="未上课头像大小"
                                         Description="未开始课程头像的像素大小（20-64）。">
                    <fa:SettingsExpanderItem.Footer>
                        <NumericUpDown Value="{Binding Settings.UpcomingAvatarSize}"
                                       Minimum="20" Maximum="64"
                                       Increment="4" Width="120" />
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="圆角半径"
                                         Description="值越大头像越圆，0 为方形，50 为圆形。">
                    <fa:SettingsExpanderItem.Footer>
                        <NumericUpDown Value="{Binding Settings.AvatarCornerRadius}"
                                       Minimum="0" Maximum="50"
                                       Increment="5" Width="120" />
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

            </fa:SettingsExpander>

            <!-- ===== 课程效果 ===== -->
            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xF265;}"
                                 Header="课程效果"
                                 Description="已上科目与未上科目的视觉处理。"
                                 IsExpanded="True">

                <fa:SettingsExpanderItem Content="已上课不透明度"
                                         Description="已结束课程头像的不透明度。">
                    <fa:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider Minimum="0" Maximum="1" Width="130"
                                    Value="{Binding Settings.PastClassOpacity}"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Classes="auto-tooltip"
                                    ci:SliderDragTooltipAssist.StringFormat="P0" />
                            <TextBlock Text="{Binding Settings.PastClassOpacity, StringFormat='{}{0:P0}'}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       FontSize="12" Opacity="0.7" Width="36" />
                        </StackPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="已上课饱和度"
                                         Description="已结束课程头像的色彩饱和度（0 为全灰）。">
                    <fa:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider Minimum="0" Maximum="1" Width="130"
                                    Value="{Binding Settings.PastClassSaturation}"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Classes="auto-tooltip"
                                    ci:SliderDragTooltipAssist.StringFormat="P0" />
                            <TextBlock Text="{Binding Settings.PastClassSaturation, StringFormat='{}{0:P0}'}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       FontSize="12" Opacity="0.7" Width="36" />
                        </StackPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="未上课不透明度"
                                         Description="未开始课程头像的不透明度。">
                    <fa:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider Minimum="0" Maximum="1" Width="130"
                                    Value="{Binding Settings.UpcomingClassOpacity}"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Classes="auto-tooltip"
                                    ci:SliderDragTooltipAssist.StringFormat="P0" />
                            <TextBlock Text="{Binding Settings.UpcomingClassOpacity, StringFormat='{}{0:P0}'}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       FontSize="12" Opacity="0.7" Width="36" />
                        </StackPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="隐藏已上课程"
                                         Description="不再显示已结束的课程头像。">
                    <fa:SettingsExpanderItem.Footer>
                        <ToggleSwitch IsChecked="{Binding Settings.HidePastClasses}" />
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

            </fa:SettingsExpander>

            <!-- ===== 高级设置 ===== -->
            <fa:SettingsExpander IconSource="{ci:FluentIconSource &#xEF27;}"
                                 Header="高级设置"
                                 Description="课程表的行为与占位符设置。"
                                 IsExpanded="False">
                <StackPanel Spacing="8" Margin="0,8,0,0">

                    <!-- 头像间距 -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="头像间距" FontSize="12" Opacity="0.7" />
                        <TextBlock Text="头像之间的水平间距（0-16px）。" FontSize="11" Opacity="0.5" />
                        <NumericUpDown Value="{Binding Settings.AvatarSpacing}"
                                       Minimum="0" Maximum="16"
                                       Increment="1" Width="120" />
                    </StackPanel>

                    <!-- 上课时仅显示当前课程 -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="上课时仅显示当前课程" FontSize="13"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch IsChecked="{Binding Settings.ShowOnlyCurrentInClass}" />
                    </StackPanel>

                    <!-- 无课程时显示占位符 -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="无课程时显示占位符" FontSize="13"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch IsChecked="{Binding Settings.ShowPlaceholder}" />
                    </StackPanel>

                    <!-- 启用入场动画 -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="启用入场动画" FontSize="13"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch IsChecked="{Binding Settings.EnableEntranceAnimation}" />
                    </StackPanel>

                    <!-- 占位符文字 -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="占位符文字" FontSize="12" Opacity="0.7" />
                        <TextBlock Text="无课程时显示的占位文字。" FontSize="11" Opacity="0.5" />
                        <TextBox Text="{Binding Settings.PlaceholderText}"
                                 Width="180" />
                    </StackPanel>

                </StackPanel>
            </fa:SettingsExpander>

        </StackPanel>
    </ScrollViewer>

</ci:ComponentBase>
